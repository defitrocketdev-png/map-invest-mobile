
# Environment Configuration Template
# Copy this file to .env, .env.preview, .env.prod, or .env.sol and fill in the values

# Build Profile (development, preview, production)
EAS_BUILD_PROFILE=

# App Information
APP_NAME=
APP_VERSION=

# Build Numbers (increment for each build)
IOS_BUILD_NUMBER=
ANDROID_VERSION_CODE=

# App Identifiers (must be unique per environment)
ANDROID_PACKAGE=
IOS_BUNDLE_ID=

PROJECT_ID=

# UI Configuration
BACKGROUND_COLOR=

# API/Web Configuration
WEB_URL=
API_BASE_URL=

# Feature Flags
ENABLE_ANALYTICS=
ENABLE_DEBUG_LOGS=
